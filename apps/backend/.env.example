# Database
DATABASE_URL="postgresql://username:password@localhost:5432/stratto"

# JWT Secret (mude para uma chave segura em produção)
# OBRIGATÓRIO — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""

# OBRIGATÓRIO — origens permitidas no CORS (separadas por vírgula)
# Exemplo: https://app.stratto.com,https://www.stratto.com
ALLOWED_ORIGINS="http://localhost:5173"

# Neon Auth (opcional; habilita o fluxo gerenciado quando configurado)
NEON_AUTH_URL=""
NEON_AUTH_BASE_URL=""
NEON_AUTH_COOKIE_SECRET=""
NEON_AUTH_RESET_REDIRECT_URL="http://localhost:5173/reset-password"
FRONTEND_URL="http://localhost:5173"
