generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      UserRole @default(BARTENDER)
  createdAt DateTime @default(now())
  createdBy String

  establishments       EstablishmentUser[]
  passwordResetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([token])
  @@index([expiresAt])
}

model Lead {
  id                String   @id @default(uuid())
  name              String
  email             String
  phone             String?
  establishmentName String
  createdAt         DateTime @default(now())

  @@index([email])
}

enum UserRole {
  ADMIN
  MANAGER
  BARTENDER
  CHEF
}

model Establishment {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  createdBy String

  users        EstablishmentUser[]
  products     Product[]
  subscription Subscription?
}

model EstablishmentUser {
  id              String @id @default(uuid())
  userId          String
  establishmentId String

  user          User          @relation(fields: [userId], references: [id])
  establishment Establishment @relation(fields: [establishmentId], references: [id])

  @@unique([userId, establishmentId])
}

model Product {
  id              String   @id @default(uuid())
  name            String
  sku             String?
  price           Float
  category        ProductCategory @default(OTHER)
  establishmentId String
  createdAt       DateTime @default(now())
  createdBy       String

  recipe Recipe?
  orderItems OrderItem[]

  establishment Establishment   @relation(fields: [establishmentId], references: [id])
  stockMovements StockMovement[]
}

enum ProductCategory {
  SPIRITS
  BEER
  WINE
  COCKTAILS
  SOFT_DRINKS
  FOOD
  OTHER
}

model Recipe {
  id        String @id @default(uuid())
  productId String @unique
  createdAt DateTime @default(now())
  createdBy String

  product Product @relation(fields: [productId], references: [id])

  items RecipeItem[]
}

model RecipeItem {
  id           String  @id @default(uuid())
  recipeId     String
  ingredientId String
  quantity     Float

  recipe     Recipe     @relation(fields: [recipeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
}

model Ingredient {
  id              String   @id @default(uuid())
  name            String
  unit            UnitType
  currentStock    Float    @default(0)
  minimumStock    Float?
  establishmentId String

  createdAt DateTime @default(now())
  createdBy String

  stockMovements StockMovement[]
  recipeItems    RecipeItem[]

  @@unique([name, establishmentId])
}

enum UnitType {
  UNIT
  ML
  L
  G
  KG
}

model StockMovement {
  id           String     @id @default(uuid())
  productId    String?
  ingredientId String?
  type         MovementType
  quantity     Float
  note         String?
  createdAt    DateTime   @default(now())
  createdBy    String

  product    Product?    @relation(fields: [productId], references: [id])
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id])
}

enum MovementType {
  IN
  OUT
  SALE
  LOSS
  ADJUSTMENT
}

model Table {
  id              String   @id @default(uuid())
  number          Int
  establishmentId String
  capacity        Int      @default(4)
  isReserved      Boolean  @default(false)
  createdAt       DateTime @default(now())

  orders Order[]

  @@unique([number, establishmentId])
}

model Order {
  id        String      @id @default(uuid())
  tableId   String
  status    OrderStatus
  total     Float
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  closedAt  DateTime?

  table Table @relation(fields: [tableId], references: [id])

  items OrderItem[]
}

enum OrderStatus {
  OPEN
  CLOSED
  CANCELED
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Plan {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String?
  priceCents    Int
  currency      String   @default("EUR")
  billingCycle  BillingCycle @default(MONTHLY)
  trialDays     Int      @default(14)
  maxUsers      Int
  maxProducts   Int
  maxTables     Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model Subscription {
  id                 String   @id @default(uuid())
  establishmentId    String   @unique
  planId             String
  status             SubscriptionStatus
  startedAt          DateTime @default(now())
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  plan          Plan          @relation(fields: [planId], references: [id])
  billings      BillingHistory[]

  @@index([status])
  @@index([planId])
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model BillingHistory {
  id                String        @id @default(uuid())
  subscriptionId    String
  provider          PaymentProvider
  providerReference String?
  amountCents       Int
  currency          String        @default("EUR")
  status            BillingStatus
  dueAt             DateTime?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@index([status])
}

enum BillingStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  MOLLIE
  ADYEN
}
